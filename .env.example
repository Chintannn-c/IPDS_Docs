# Base URL Configuration for different platforms/environments
# Copy this file to .env and update with your actual server IPs

# Android Emulator (10.0.2.2 is the special alias for localhost on Android emulator)
BASE_URL_ANDROID=http://10.0.2.2:8000

# Android Physical Device (Replace YOUR_PC_LAN_IP with your computer's local network IP)
BASE_URL_ANDROID_PHYSICAL=http://YOUR_PC_LAN_IP:8000

# iOS Emulator
BASE_URL_IOS=http://127.0.0.1:8000

# iOS Physical Device (Replace YOUR_PC_LAN_IP with your computer's local network IP)
BASE_URL_IOS_PHYSICAL=http://YOUR_PC_LAN_IP:8000

# Web Browser
BASE_URL_WEB=http://127.0.0.1:8000

# Desktop (Windows/macOS/Linux)
BASE_URL_DESKTOP=http://127.0.0.1:8000
